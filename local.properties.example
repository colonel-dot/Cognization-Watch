## Copy these keys into local.properties and fill local values.
## local.properties is ignored by Git.

# Android SDK path is usually generated by Android Studio.
# sdk.dir=C\:\\Users\\<you>\\AppData\\Local\\Android\\Sdk

release.storeFile=../release.jks
release.storePassword=
release.keyAlias=key0
release.keyPassword=

amap.apiKey=
api.baseUrl=http://127.0.0.1:8080/

# Development-only TRTC config. Move UserSig generation to a server before release.
trtc.sdkAppId=0
trtc.sdkSecretKey=
