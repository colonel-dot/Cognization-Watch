<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.bridge.main.ChildrenActivity">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="Geofence"
        android:textColor="@color/blue"
        android:textSize="24sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        />

    <TextView
        android:id="@+id/hello"
        android:layout_width="match_parent"
        android:layout_height="21dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:text="Set and monitor safe area"
        android:textColor="@color/grey"
        android:textSize="12sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/hello"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/white_background"
        android:clipToOutline="true"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true">

        <TextView
            android:id="@+id/inner_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:text="Current Location"
            android:textSize="18sp"
            android:fontFamily="@font/harmonyos_sans_bold"
            />

        <TextView
            android:id="@+id/location"
            android:layout_width="80dp"
            android:layout_height="30dp"
            android:text="Inside"
            android:textColor="@color/white"
            android:background="@drawable/background_rounded"
            android:backgroundTint="@color/cyan"
            android:fontFamily="@font/harmonyos_sans_bold"
            app:layout_constraintStart_toEndOf="@id/inner_title"
            app:layout_constraintTop_toTopOf="@id/inner_title"
            app:layout_constraintBottom_toBottomOf="@id/inner_title"
            android:gravity="center"
            android:layout_marginStart="10dp"
            android:stateListAnimator="@animator/button_press"
            android:clickable="true"
            />

        <FrameLayout
            android:id="@+id/inner_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/inner_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@drawable/background_rounded"
            android:backgroundTint="@color/light_grey"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:clipToOutline="true">

            <com.example.bridge.geofence.map.view.MapWebView
                android:id="@+id/map"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/activity"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/white_background"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true">

        <TextView
            android:id="@+id/inner_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:text="Recent Activity"
            android:textSize="18sp"
            android:fontFamily="@font/harmonyos_sans_bold"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/record"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/inner_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>