<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/background_rounded"
    android:backgroundTint="@color/light_orange"
    android:stateListAnimator="@animator/button_press"
    android:clickable="true">

    <ImageView
        android:id="@+id/icon"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/careful"
        android:tint="@color/orange"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:padding="4dp"
        />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="最近预警"
        android:textColor="@color/orange"
        android:textSize="18sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        app:layout_constraintTop_toTopOf="@id/icon"
        app:layout_constraintBottom_toBottomOf="@id/icon"
        app:layout_constraintStart_toEndOf="@id/icon"
        android:layout_marginStart="3dp"
        />

    <LinearLayout
        android:id="@+id/tip"
        android:layout_width="200dp"
        android:layout_height="36dp"
        android:background="@drawable/background_rounded_light"
        android:backgroundTint="@color/white_background"
        app:layout_constraintTop_toBottomOf="@id/icon"
        app:layout_constraintStart_toStartOf="@id/icon"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/point"
            android:tint="@color/orange"
            />

        <TextView
            android:id="@+id/introduce"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="长辈离开守护范围"
            android:fontFamily="@font/harmonyos_sans_bold"
            />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>