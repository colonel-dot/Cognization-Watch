<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="170dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/background_rounded"
    android:backgroundTint="@color/white_background"
    android:stateListAnimator="@animator/button_press"
    android:clickable="true">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="风险指数"
        android:textSize="18dp"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        />

    <TextView
        android:id="@+id/assess"
        android:layout_width="100dp"
        android:layout_height="30dp"
        android:text="Medium Risk"
        android:textColor="@color/white"
        android:background="@drawable/background_rounded"
        android:fontFamily="@font/harmonyos_sans_bold"
        app:layout_constraintStart_toEndOf="@id/title"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        android:gravity="center"
        android:layout_marginStart="10dp"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true"
        />

    <TextView
        android:id="@+id/val"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="85"
        android:textSize="40dp"
        android:textColor="@color/green"
        android:fontFamily="@font/harmonyos_sans_bold"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toTopOf="@id/highest"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp"
        app:layout_constraintVertical_chainStyle="packed"
        />

    <TextView
        android:id="@+id/highest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="out of 100"
        android:textColor="@color/grey"
        android:fontFamily="@font/harmonyos_sans_bold"
        app:layout_constraintTop_toBottomOf="@id/val"
        app:layout_constraintBottom_toTopOf="@id/trend"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp"
        />

    <TextView
        android:id="@+id/trend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="据上周增长5%"
        android:fontFamily="@font/harmonyos_sans_bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="15dp"
        />


</androidx.constraintlayout.widget.ConstraintLayout>