<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background_top_rounded"
    android:backgroundTint="@color/white_background"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/light_grey" />

    <TextView
        android:id="@+id/date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2024-05-20"
        android:textColor="@color/grey"
        android:textSize="14sp"
        android:fontFamily="@font/harmonyos_sans_bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="风险评估报告"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/harmonyos_sans_bold"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#F8F9FA"
        app:cardCornerRadius="25dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/light_grey"
        app:strokeWidth="0dp"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true"
        app:rippleColor="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="低风险"
                    android:textColor="@color/cyan"
                    android:textSize="18sp"
                    android:fontFamily="@font/harmonyos_sans_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="认知风险总评"
                    android:textSize="12sp"
                    android:fontFamily="@font/harmonyos_sans_bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="12"
                android:textSize="32sp"
                android:fontFamily="@font/harmonyos_sans_bold"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="详细行为指数"
        android:textSize="16sp"
        android:fontFamily="@font/harmonyos_sans_bold" />

    <TextView
        android:id="@+id/behavior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="8dp"
        android:text="数据加载中..."
        android:textSize="14sp"
        android:fontFamily="@font/harmonyos_sans_bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="详细风险指数"
        android:textSize="16sp"
        android:fontFamily="@font/harmonyos_sans_bold" />

    <TextView
        android:id="@+id/detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="8dp"
        android:text="数据加载中..."
        android:textSize="14sp"
        android:fontFamily="@font/harmonyos_sans_bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/light_grey" />

    <TextView
        android:id="@+id/explanations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/light_orange"
        android:padding="12dp"
        android:text="专家建议：保持充足睡眠"
        android:textColor="@color/yellow"
        android:textSize="13sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true" />

</LinearLayout>