<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/blue_grey"
    tools:context="schulte.ui.SchulteGridActivity">

    <TextView
        android:id="@+id/function"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="舒尔特方格"
        android:textColor="@color/blue"
        android:textSize="24sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        />

    <TextView
        android:id="@+id/hint"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        app:layout_constraintTop_toBottomOf="@id/function"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:text="尽快依次点击1到25"
        android:textColor="@color/grey"
        android:textSize="18sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        />

    <LinearLayout
        android:id="@+id/left"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/green"
        android:clickable="true"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:gravity="center"
        android:orientation="vertical"
        android:stateListAnimator="@animator/button_press"
        android:text="时间"
        android:textColor="@color/white"
        app:layout_constraintEnd_toStartOf="@id/right"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hint"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/harmonyos_sans_bold"
            android:text="用时"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/harmonyos_sans_bold"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/right"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/green"
        android:clickable="true"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:gravity="center"
        android:orientation="vertical"
        android:stateListAnimator="@animator/button_press"
        android:text="方格数"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/left"
        app:layout_constraintTop_toBottomOf="@id/hint"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/harmonyos_sans_bold"
            android:text="点击方格数"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/grid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/harmonyos_sans_bold"
            android:text="0 / 25"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/schulte"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/white_background"
        android:clipToOutline="true"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/left"
        app:layout_constraintWidth_percent="0.97" />

    <TextView
        android:id="@+id/pause"
        android:layout_width="120dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/schulte"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/start"
        android:layout_marginTop="20dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/blue"
        android:gravity="center"
        android:text="暂停"
        android:textColor="@color/white"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true"
        />

    <TextView
        android:id="@+id/start"
        android:layout_width="120dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/schulte"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/pause"
        android:layout_marginTop="20dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/blue"
        android:gravity="center"
        android:text="开始"
        android:textColor="@color/white"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true"
        />

</androidx.constraintlayout.widget.ConstraintLayout>