<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/blue_grey"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <com.example.cogwatch.login.ui.view.TypewriterTextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="30dp"
        android:gravity="center_vertical|start"
        android:text="怎么称呼您？"
        android:textColor="@color/blue"
        android:textSize="24sp"
        android:fontFamily="@font/harmonyos_sans_bold" />

    <TextView
        android:id="@+id/hello"
        android:layout_width="match_parent"
        android:layout_height="21dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:text="首次登录的账号将自动注册"
        android:textColor="@color/grey"
        android:textSize="12sp"
        android:fontFamily="@font/harmonyos_sans_bold" />

    <TextView
        android:id="@+id/elder"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/green"
        android:text="长辈"
        android:textColor="@color/white"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/hello"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/children"
        android:layout_marginTop="20dp"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true" />

    <TextView
        android:id="@+id/children"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/green"
        android:text="子女"
        android:textColor="@color/white"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/elder"
        app:layout_constraintStart_toEndOf="@id/elder"
        app:layout_constraintEnd_toEndOf="parent"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true" />

    <EditText
        android:id="@+id/username"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/white_background"
        android:hint="用户名"
        android:inputType="text"
        android:paddingLeft="15dp"
        android:textColorHint="@color/light_grey"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/elder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true" />

    <EditText
        android:id="@+id/password"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/background_rounded"
        android:backgroundTint="@color/white_background"
        android:hint="密码"
        android:inputType="textPassword"
        android:paddingLeft="15dp"
        android:textColorHint="@color/light_grey"
        app:layout_constraintTop_toBottomOf="@id/username"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true" />

    <Button
        android:id="@+id/login"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:backgroundTint="@color/blue"
        android:text="登录"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:stateListAnimator="@animator/button_press"
        android:clickable="true"
        android:layout_marginBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guest_login" />

    <TextView
        android:id="@+id/guest_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="游客登录"
        android:textColor="@color/blue"
        android:textSize="14sp"
        android:fontFamily="@font/harmonyos_sans_bold"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
